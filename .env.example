# Proco x402 Facilitator — Environment Variables

# Proco API key (get one at procohq.com)
PROCO_API_KEY=sk_sandbox_...

# Network: base-sepolia (testnet) or base (mainnet)
NETWORK=base-sepolia

# Settlement wallet private key (holds USDC to cover settlements)
# For sandbox: use a testnet key — no real funds needed
SETTLEMENT_PRIVATE_KEY=0x...

# Base RPC URL (get one free at https://www.coinbase.com/developer-platform)
BASE_RPC_URL=https://mainnet.base.org

# Server port (default: 3402)
PORT=3402
